// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Organization Table
model Organization {
  id                        String                   @id @default(uuid()) @db.Uuid
  name                      String                   @db.Text
  admin_email               String                   @db.Text
  users                     User[]
  organization_linked_users OrganizationLinkedUser[]
  roles                     Role[]
  logo                      String?                   @db.Text
  created_at                DateTime                 @default(now()) @db.Timestamptz()
  updated_at                DateTime                 @updatedAt @db.Timestamptz()
}

// User Table
model User {
  id                 String                   @id @default(uuid()) @db.Uuid
  email              String                   @db.Text
  first_name         String?                   @db.Text
  last_name          String ?                  @db.Text
  age                Int?                      @db.Integer
  profile_image      String?                  @db.Uuid
  organizations      Organization[] //User can belong multiple organization
  organization_links OrganizationLinkedUser[]
  created_by_type  UserCreatedBy
  created_at         DateTime                 @default(now()) @db.Timestamptz()
  updated_at         DateTime                 @updatedAt @db.Timestamptz()
}

model OrganizationLinkedUser {
  id              Int          @id @default(autoincrement())
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  user_id         String       @db.Uuid
  user            User         @relation(fields: [user_id], references: [id])
  is_active       Boolean      @default(false)
  is_deactived    Boolean      @default(false)
  rold_id         String
  role            Role         @relation(fields: [rold_id], references: [id])
  created_at      DateTime     @default(now()) @db.Timestamptz()
  updated_at      DateTime     @updatedAt @db.Timestamptz()

  @@unique([organization_id, user_id])
}

// Role Table
model Role {
  id                        String                   @id @default(cuid()) @db.Text
  name                      String                   @db.Text
  is_system                 Boolean
  organization_id           String                   @db.Uuid
  organization              Organization             @relation(fields: [organization_id], references: [id])
  organization_linked_users OrganizationLinkedUser[]
  permissions               Permission[]
  created_at                DateTime                 @default(now()) @db.Timestamptz()
  updated_at                DateTime                 @updatedAt @db.Timestamptz()
}

// Permission Table
model Permission {
  id         String   @id @default(cuid())
  name       String   @db.Text
  roles      Role[]
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @updatedAt @db.Timestamptz()
}


enum UserCreatedBy {
  USER
  ORGANIZATION
}