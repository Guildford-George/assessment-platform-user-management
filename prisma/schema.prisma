// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Organization Table
model Organization {
  id                        String                   @id @default(uuid()) @db.Uuid
  name                      String                   @db.Text
  admin_email               String                   @db.Text
  organization_linked_users OrganizationLinkedUser[]
  status                    AccountStatus            @default(INACTIVE)
  logo                      String?                  @db.Text
  created_at                DateTime                 @default(now()) @db.Timestamptz()
  updated_at                DateTime                 @updatedAt @db.Timestamptz()
}

// User Table
model User {
  id                 String                   @id @default(uuid()) @db.Uuid
  email              String                   @unique @db.Text
  first_name         String?                  @db.Text
  last_name          String?                  @db.Text
  age                Int?                     @db.Integer
  profile_image      String?                  @db.Uuid
  organization_links OrganizationLinkedUser[]
  created_by_type    UserCreatedBy
  created_at         DateTime                 @default(now()) @db.Timestamptz()
  updated_at         DateTime                 @updatedAt @db.Timestamptz()
}

model OrganizationLinkedUser {
  id              Int           @id @default(autoincrement())
  organization_id String        @db.Uuid
  organization    Organization  @relation(fields: [organization_id], references: [id])
  user_id         String        @db.Uuid
  user            User          @relation(fields: [user_id], references: [id])
  status          AccountStatus @default(INACTIVE)
  role_id         String
  role_name       String
  created_at      DateTime      @default(now()) @db.Timestamptz()
  updated_at      DateTime      @updatedAt @db.Timestamptz()

  @@unique([organization_id, user_id])
}


enum UserCreatedBy {
  USER
  ORGANIZATION
}

enum AccountStatus {
  INACTIVE
  ACTIVE
  DEACTIVED
}
